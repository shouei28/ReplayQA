[flake8]
max-line-length = 127
exclude = 
    migrations,
    venv,
    __pycache__,
    .git,
    .venv,
    manage.py,
    settings.py
ignore = 
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
    E203,  # whitespace before ':'
per-file-ignores =
    __init__.py:F401
